# Toolchain Configuration
cxx = g++
ar = ar
linker = g++

# Platform-Specific Flags
platform_cflags = 
platform_lflags = 

# Profile-Specific Flags
profile_cflags = -DDEBUG  -O0 -fstack-protector -g -std=c++20 -finput-charset=UTF-8 
profile_lflags = -DEBUG 

# ------------------------------------------------------------
# Rules for Compiling C++ Modules
# ------------------------------------------------------------
rule module_compile
  command = $cxx -std=c++20 -fmodules-ts -c $in -o $out -fmodule-output=build/debug/modules/ $cflags
  description = Compiling C++ module $in

# ------------------------------------------------------------
# Compilation, Archiving, and Linking Rules
# ------------------------------------------------------------
rule compile
  command = $cxx -c $in -o $out $profile_cflags $platform_cflags $cflags
  description = Compiling $in

rule archive
  command = $ar rcs $out $in
  description = Archiving $out

rule link
  command = $linker $in -o $out $profile_lflags $platform_lflags $lflags $libraries
  description = Linking $out

